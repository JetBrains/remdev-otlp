<idea-plugin>
    <dependencies>
        <module name="intellij.platform.backend"/>
        <module name="intellij.platform.kernel.backend"/>
        <module name="intellij.platform.remoteController.backend"/>
        <module name="intellij.platform.rpc"/>
        <module name="intellij.platform.rpc.backend"/>
        <module name="intellij.rd.platform"/>
        <module name="OtpDiagnostic.shared"/>
        <plugin id="com.jetbrains.remoteDevelopment"/>
    </dependencies>

    <applicationListeners>
        <listener class="com.jetbrains.otp.connection.OtpWireTransportListener"
                  topic="com.intellij.platform.split.connection.protocol.transport.WireTransportListener"/>
        <listener class="com.jetbrains.otp.connection.ExpectedDisconnectAppLifecycleListener"
                  topic="com.intellij.ide.AppLifecycleListener"/>
    </applicationListeners>

    <extensions defaultExtensionNs="com.intellij">
        <openTelemetryExporterProvider implementation="com.jetbrains.otp.exporter.BackendMetricExporter"/>

        <postStartupActivity implementation="com.jetbrains.otp.exporter.BackendOtlpInitializer"/>

        <platform.rpc.backend.remoteApiProvider implementation="com.jetbrains.otp.settings.OtpDiagnosticSettingsApiProvider"/>
        <platform.rpc.backend.remoteApiProvider implementation="com.jetbrains.otp.span.OtpSessionSpanApiProvider"/>
        <platform.rpc.backend.remoteApiProvider implementation="com.jetbrains.otp.crypto.CryptoRpcProvider"/>
    </extensions>
</idea-plugin>
